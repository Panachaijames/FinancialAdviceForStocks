# PT Financial Advisor — environment configuration (all optional).
# Copy to ".env" (bundled into the desktop build) or ".env.local" (dev only, not bundled).
#
# The app works with NO keys (Yahoo Finance, crumb-free). These keys add a
# resilient FALLBACK when Yahoo throttles, plus the optional AI Insights panel.

# Twelve Data — fallback for symbol search, US stock/gold quotes & candles.
# Free key (8 req/min, 800/day): https://twelvedata.com/pricing  (Thai SET needs a paid plan)
TWELVEDATA_KEY=

# Finnhub — primary news source (per-symbol + general market news).
# Free key (60 req/min): https://finnhub.io/register
FINNHUB_KEY=

# Google Gemini — powers the optional "AI Insights" panel (analysis only, NOT a
# price source). Free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Thai SEC OpenAPI — read-only Thai mutual-fund (RMF/LTF/SSF) NAV data for the
# Plan > Thai Funds panel. Two free subscription keys: https://api-portal.sec.or.th/apidesc
# (subscribe to "Fund Daily Info" and "Fund Factsheet")
SEC_FUND_DAILY_KEY=
SEC_FACTSHEET_KEY=

# Server port (defaults to 8787; the desktop app auto-picks a free port).
# PORT=8787
